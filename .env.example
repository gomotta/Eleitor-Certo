# Banco de dados
DATABASE_URL=postgresql://eleitor:eleitor123@localhost:5432/eleitor_certo
POSTGRES_USER=eleitor
POSTGRES_PASSWORD=eleitor123
POSTGRES_DB=eleitor_certo

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=troque-por-uma-string-secreta-longa-e-aleatoria
JWT_REFRESH_SECRET=troque-por-outra-string-secreta-longa
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Criptografia (CPF e título de eleitor em repouso)
ENCRYPTION_KEY=chave-hex-256-bits-troque-aqui-32bytes

# Servidor
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# IBGE API (não precisa de chave, mas útil para documentar)
IBGE_API_URL=https://servicodados.ibge.gov.br/api/v1
